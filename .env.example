# ----------------------------------------------------------------------------
# TypeFlow environment variables. Copy to `.env` and fill in real values.
# ----------------------------------------------------------------------------

# PostgreSQL connection string.
# Local docker-compose default shown below.
DATABASE_URL="postgresql://typeflow:typeflow@localhost:5432/typeflow?schema=public"

# NextAuth: generate a secret with `openssl rand -base64 32`
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Leave blank to disable the Google sign-in button.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Public base URL used in metadata / sitemaps.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
