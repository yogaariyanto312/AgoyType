// TypeFlow database schema — authoritative ERD.
// Docs: ../docs/ARCHITECTURE.md  §3 Data Model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum TestMode {
  TIME
  WORDS
  QUOTE
  CUSTOM
  ZEN
}

enum RaceStatus {
  WAITING
  COUNTDOWN
  RACING
  FINISHED
}

// ---------------------------------------------------------------------------
// Auth (NextAuth adapter tables)
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  password      String? // bcrypt hash; null for pure-OAuth users
  image         String?
  bio           String?   @db.VarChar(280)
  keyboard      String? // free-text "what keyboard do you use"
  role          Role      @default(USER)
  banned        Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  results       Result[]
  personalBests PersonalBest[]
  achievements  UserAchievement[]
  dailyStats    DailyStat[]
  raceEntries   RaceParticipant[]

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Typing results
// ---------------------------------------------------------------------------

model Result {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // headline metrics
  wpm         Float
  rawWpm      Float
  accuracy    Float // 0-100
  consistency Float // 0-100
  errors      Int   @default(0)
  keystrokes  Int   @default(0)

  // configuration that produced this result
  mode      TestMode
  mode2     String // "time:60", "words:50", "quote:medium", ...
  language  String   @default("english")
  duration  Float // actual seconds elapsed
  testText  String?  @db.Text

  // character breakdown: { correct, incorrect, extra, missed }
  charStats Json
  // per-second samples: [{ t, wpm, raw, errors }]
  rawData   Json

  // integrity
  flagged       Boolean @default(false)
  flagReason    String?
  isPersonalBest Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([mode, mode2, wpm])
  @@index([wpm])
  @@index([createdAt])
}

model PersonalBest {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // composite key of the test "category"
  mode     TestMode
  mode2    String
  language String   @default("english")

  wpm         Float
  rawWpm      Float
  accuracy    Float
  consistency Float
  resultId    String?

  achievedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, mode, mode2, language])
  @@index([mode, mode2, wpm])
}

// ---------------------------------------------------------------------------
// Aggregates & gamification
// ---------------------------------------------------------------------------

model DailyStat {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day    DateTime @db.Date

  testsCompleted Int   @default(0)
  timeTyping     Float @default(0) // seconds
  totalWpm       Float @default(0) // sum, for averaging
  bestWpm        Float @default(0)
  keystrokes     Int   @default(0)

  @@unique([userId, day])
  @@index([day])
}

model Achievement {
  id          String @id @default(cuid())
  key         String @unique // e.g. "speed_100"
  name        String
  description String
  icon        String // lucide icon name
  tier        String @default("bronze") // bronze|silver|gold|platinum

  users UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Content (admin-manageable)
// ---------------------------------------------------------------------------

model WordList {
  id       String   @id @default(cuid())
  language String   @unique
  name     String
  words    String[] // simple frequency-ordered list
  enabled  Boolean  @default(true)
}

model Quote {
  id       String  @id @default(cuid())
  text     String  @db.Text
  source   String
  language String  @default("english")
  length   String // short|medium|long|thicc
  enabled  Boolean @default(true)

  @@index([language, length])
}

// ---------------------------------------------------------------------------
// Multiplayer (schema ready; realtime engine is roadmap — see ARCHITECTURE §7)
// ---------------------------------------------------------------------------

model RaceRoom {
  id        String     @id @default(cuid())
  code      String     @unique // shareable 6-char room code
  hostId    String
  isPrivate Boolean    @default(false)
  status    RaceStatus @default(WAITING)
  mode      TestMode   @default(TIME)
  mode2     String     @default("time:30")
  testText  String     @db.Text
  language  String     @default("english")
  createdAt DateTime   @default(now())
  startedAt DateTime?
  finishedAt DateTime?

  participants RaceParticipant[]

  @@index([status])
}

model RaceParticipant {
  id     String @id @default(cuid())
  roomId String
  room   RaceRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId String?
  user   User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  guestName   String?
  isSpectator Boolean @default(false)
  progress    Float   @default(0) // 0-100
  wpm         Float   @default(0)
  finished    Boolean @default(false)
  finishRank  Int?
  joinedAt    DateTime @default(now())

  @@unique([roomId, userId])
  @@index([roomId])
}
